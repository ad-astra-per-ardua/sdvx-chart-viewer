# Local dev — SQLite, zero setup.
DATABASE_URL=sqlite:///./data/songs.db

# Production / Supabase example (uncomment & fill):
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Admin auth — required for /api/admin/* endpoints.
# Generate something long & random in production, e.g.: openssl rand -hex 32
ADMIN_TOKEN=change-me-in-production

# Public base URL used to build uploaded-file URLs.
# Leave empty to serve relative paths (works with the vite proxy in dev).
PUBLIC_BASE_URL=
