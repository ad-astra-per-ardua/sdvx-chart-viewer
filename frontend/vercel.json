{
  "rewrites": [
    { "source": "/api/:path*",     "destination": "https://sdvx-chart-viewer-production.up.railway.app/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://sdvx-chart-viewer-production.up.railway.app/uploads/:path*" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/no-jacket.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
